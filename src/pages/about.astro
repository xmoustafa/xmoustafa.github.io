---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

const skillGroups = [
	{
		title: "Web & API Security",
		items: [
			"OWASP Top 10",
			"Access Control Testing",
			"Authentication Testing",
			"XSS & Blind XSS",
			"Business Logic Testing",
			"Rate Limiting",
			"Input Validation",
			"API Security",
		],
	},
	{
		title: "Offensive Tooling",
		items: [
			"Burp Suite Professional",
			"Nmap",
			"Nessus",
			"Metasploit",
			"SQLMap",
			"OWASP ZAP",
			"Nuclei",
			"ffuf",
			"dirsearch",
			"Amass",
			"Subfinder",
			"httpx",
			"Katana",
		],
	},
	{
		title: "Reverse Engineering",
		items: [
			"IDA Pro",
			"Ghidra",
			"Binary Ninja",
			"x64dbg",
			"PEStudio",
			"PE-bear",
			"Detect It Easy",
			"Static Analysis",
			"Dynamic Analysis",
			"Control-Flow Analysis",
		],
	},
	{
		title: "Malware Analysis",
		items: [
			"ProcMon",
			"Process Hacker",
			"API Monitor",
			"Wireshark",
			"String Analysis",
			"Import Analysis",
			"Behavior Analysis",
			"IOC Extraction",
			"Basic YARA Rules",
		],
	},
	{
		title: "Programming & Scripting",
		items: [
			"Python",
			"Bash",
			"PowerShell",
			"C++",
			"JavaScript",
			"PHP",
			"x86/x64 Assembly",
		],
	},
	{
		title: "Systems & Networking",
		items: [
			"Windows",
			"Linux",
			"macOS",
			"TCP/IP",
			"DNS",
			"HTTP/HTTPS",
			"VPN",
			"Active Directory Fundamentals",
		],
	},
];

const socialLinks = [
	{ label: "X / Twitter", href: "https://x.com/Prosox0x0", icon: "fa7-brands:x-twitter" },
	{ label: "LinkedIn", href: "https://linkedin.com/in/moustafa-abdelnabbi", icon: "fa7-brands:linkedin-in" },
	{ label: "My Blog", href: "https://xmoustafa.github.io/", icon: "fa7-solid:globe" },
	{ label: "Facebook", href: "https://facebook.com/Moustafa.0x1337", icon: "fa7-brands:facebook-f" },
	{ label: "Email", href: "mailto:moustafa.abdelnaby@outlook.com", icon: "fa7-solid:envelope" },
	{ label: "Discord · 1p_rootx", href: "https://discord.com/users/1p_rootx", icon: "fa7-brands:discord" },
];
---

<MainGridLayout
	title="About"
	description="Penetration Tester and Security Researcher with more than seven years of independent application-security experience."
>
	<section class="about-brand-page card-base p-5 md:p-8">
		<header class="about-page-header">
			<span class="about-kicker">IDENTITY // PROSOX</span>
			<h1>About</h1>
			<p>Security research, offensive testing, and technical investigation.</p>
		</header>

		<div class="about-layout">
			<aside class="identity-card">
				<div class="identity-frame">
					<img src="/assets/images/prosox-avatar.png" alt="Prosox0x0 cybersecurity portrait" />
				</div>
				<p class="identity-handle">PROSOX</p>
				<h2>Penetration Tester<br />& Security Researcher</h2>
				<div class="experience-badge">7+ YEARS · INDEPENDENT EXPERIENCE</div>

				<nav class="identity-links" aria-label="Prosox0x0 social links">
					{
						socialLinks.map((link) => (
							<a href={link.href} target="_blank" rel="me noopener noreferrer">
								<Icon name={link.icon} />
								{link.label}
							</a>
						))
					}
				</nav>
			</aside>

			<div class="about-content">
				<article class="about-panel profile-summary">
					<p class="panel-index">01 // PROFILE</p>
					<h2>Penetration Tester & Security Researcher</h2>
					<p>
						I bring more than seven years of independent bug bounty and
						application-security experience, supported by hands-on exposure to
						reverse engineering, malware analysis, and SOC investigations.
					</p>
					<p>
						My work spans web and API testing, OWASP Top 10 vulnerabilities,
						Burp Suite Professional, proof-of-concept development, technical
						reporting, Windows binary analysis, and x86/x64 debugging. I focus on
						identifying meaningful vulnerabilities, understanding attacker
						techniques, and translating technical findings into clear,
						actionable remediation guidance.
					</p>
				</article>

				<section class="about-panel skills-panel">
					<p class="panel-index">02 // CAPABILITIES</p>
					<h2>Core Technical Skills</h2>
					<div class="skill-groups">
						{
							skillGroups.map((group) => (
								<section class="skill-group">
									<h3>{group.title}</h3>
									<div class="skill-chips">
										{group.items.map((item) => <span>{item}</span>)}
									</div>
								</section>
							))
						}
					</div>
				</section>

				<blockquote class="brand-quote">
					<span>03 // MINDSET</span>
					<p>“Find the signal. Trace the behavior. Turn uncertainty into evidence.”</p>
				</blockquote>
			</div>
		</div>
	</section>
</MainGridLayout>

<style is:global>
	body:has(.about-brand-page) #main-grid {
		grid-template-columns: minmax(0, 1fr) !important;
		max-width: 78rem;
	}

	body:has(.about-brand-page) #main-grid > .contents {
		display: none;
	}

	body:has(.about-brand-page) #swup-container {
		grid-column: 1 / -1 !important;
	}

	.about-brand-page {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(168, 85, 247, 0.42) !important;
		background:
			linear-gradient(135deg, rgba(168, 85, 247, 0.07), transparent 36%),
			linear-gradient(315deg, rgba(34, 211, 238, 0.045), transparent 36%),
			var(--card-bg) !important;
		box-shadow: 0 0 45px rgba(168, 85, 247, 0.11) !important;
	}

	.about-brand-page::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(168, 85, 247, 0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(34, 211, 238, 0.025) 1px, transparent 1px);
		background-size: 32px 32px;
		mask-image: linear-gradient(to bottom, black, transparent 65%);
	}

	.about-page-header,
	.about-layout {
		position: relative;
		z-index: 1;
	}

	.about-page-header {
		margin-bottom: 2rem;
		padding-left: 1rem;
		border-left: 4px solid #c026ff;
	}

	.about-kicker,
	.panel-index,
	.brand-quote > span {
		color: #22d3ee;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
	}

	.about-page-header h1 {
		margin: 0.2rem 0;
		color: #f8fafc;
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 900;
		letter-spacing: -0.04em;
	}

	.about-page-header p {
		color: rgba(148, 163, 184, 0.92);
	}

	.about-layout {
		display: grid;
		grid-template-columns: minmax(16rem, 0.78fr) minmax(0, 2fr);
		gap: 1.25rem;
		align-items: start;
	}

	.identity-card,
	.about-panel,
	.brand-quote {
		border: 1px solid rgba(168, 85, 247, 0.28);
		border-radius: 1rem;
		background: rgba(10, 6, 18, 0.56);
		backdrop-filter: blur(12px);
	}

	:root:not(.dark) .identity-card,
	:root:not(.dark) .about-panel,
	:root:not(.dark) .brand-quote {
		background: rgba(255, 255, 255, 0.72);
	}

	.identity-card {
		position: sticky;
		top: 1rem;
		padding: 1.5rem;
		text-align: center;
		box-shadow: inset 0 0 35px rgba(168, 85, 247, 0.055);
	}

	.identity-frame {
		position: relative;
		width: min(11rem, 72%);
		margin: 0 auto 1.1rem;
		padding: 3px;
		border-radius: 1.1rem;
		background: linear-gradient(135deg, #22d3ee, #a855f7 52%, #ec4899);
		box-shadow: 0 0 28px rgba(168, 85, 247, 0.34);
	}

	.identity-frame img {
		display: block;
		width: 100%;
		border-radius: calc(1.1rem - 3px);
	}

	.identity-handle {
		margin: 0;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 1.65rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-shadow: 0 0 18px rgba(168, 85, 247, 0.72);
	}

	.identity-card h2 {
		margin: 0.75rem 0;
		color: rgba(148, 163, 184, 0.96);
		font-size: 0.83rem;
		font-weight: 800;
		line-height: 1.65;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.experience-badge {
		margin: 1rem 0;
		padding: 0.6rem 0.75rem;
		border: 1px solid rgba(34, 211, 238, 0.28);
		border-radius: 0.65rem;
		color: #22d3ee;
		font-family: var(--font-jetbrains-mono), monospace;
		font-size: 0.68rem;
		font-weight: 700;
	}

	.identity-links {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.65rem;
	}

	.identity-links a {
		padding: 0.68rem 0.5rem;
		border: 1px solid rgba(168, 85, 247, 0.23);
		border-radius: 0.65rem;
		background: rgba(3, 3, 8, 0.46);
		color: #e879f9;
		font-size: 0.76rem;
		font-weight: 800;
		text-decoration: none;
		transition: 180ms ease;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
	}

	.identity-links a :global(svg) {
		width: 1rem;
		height: 1rem;
		flex: none;
	}

	:root:not(.dark) .identity-links a {
		background: rgba(168, 85, 247, 0.06);
		color: #7e22ce;
	}

	.identity-links a:hover {
		border-color: #22d3ee;
		color: #22d3ee;
		box-shadow: 0 0 18px rgba(34, 211, 238, 0.15);
		transform: translateY(-2px);
	}

	.about-content {
		display: grid;
		gap: 1rem;
	}

	.about-panel,
	.brand-quote {
		padding: 1.4rem 1.5rem;
		border-left: 4px solid #a855f7;
	}

	.about-panel h2 {
		margin: 0.35rem 0 1rem;
		color: #f8fafc;
		font-size: 1.45rem;
	}

	.identity-handle,
	.brand-quote p {
		color: #f8fafc;
	}

	:root:not(.dark) .about-page-header h1,
	:root:not(.dark) .about-panel h2,
	:root:not(.dark) .identity-handle,
	:root:not(.dark) .brand-quote p {
		color: #0f172a;
	}

	.profile-summary p:not(.panel-index) {
		color: rgba(203, 213, 225, 0.88);
		line-height: 1.85;
	}

	:root:not(.dark) .profile-summary p:not(.panel-index) {
		color: #475569;
	}

	.skill-groups {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.skill-group {
		padding: 1rem;
		border: 1px solid rgba(34, 211, 238, 0.13);
		border-radius: 0.8rem;
		background: rgba(34, 211, 238, 0.025);
	}

	.skill-group h3 {
		margin: 0 0 0.75rem;
		color: #22d3ee;
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.skill-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.skill-chips span {
		padding: 0.38rem 0.65rem;
		border: 1px solid rgba(168, 85, 247, 0.42);
		border-radius: 999px;
		background: rgba(168, 85, 247, 0.10);
		color: #e9d5ff;
		font-size: 0.72rem;
		font-weight: 700;
	}

	:root:not(.dark) .skill-chips span {
		color: #6b21a8;
	}

	.brand-quote {
		margin: 0;
		border-left-color: #ec4899;
		background: linear-gradient(120deg, rgba(168, 85, 247, 0.11), rgba(34, 211, 238, 0.055));
	}

	.brand-quote p {
		margin: 0.65rem 0 0;
		font-size: clamp(1rem, 2.5vw, 1.35rem);
		font-style: italic;
		font-weight: 700;
		line-height: 1.65;
	}

	@media (max-width: 820px) {
		.about-layout,
		.skill-groups {
			grid-template-columns: 1fr;
		}

		.identity-card {
			position: relative;
			top: auto;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.identity-links a {
			transition: none;
		}
	}
</style>
