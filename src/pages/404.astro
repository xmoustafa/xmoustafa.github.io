---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout
	title="404 — Packet Lost"
	description="This route escaped the network."
>
	<div class="error-shell card-base">
		<div class="scanline" aria-hidden="true"></div>
		<div class="terminal-bar">
			<span></span><span></span><span></span>
			<p>prosox@security-lab:~</p>
		</div>

		<div class="error-content">
			<div class="glitch-code" data-text="404">404</div>
			<p class="status"><span></span> ROUTE_NOT_FOUND</p>
			<h1>Well… this packet took a wrong turn.</h1>
			<div class="terminal-output" aria-label="Terminal error details">
				<p><b>$</b> trace-route requested-page</p>
				<p>Hop 1: browser <em>[OK]</em></p>
				<p>Hop 2: blog <em>[OK]</em></p>
				<p>Hop 3: page <strong>[VANISHED INTO THE VOID]</strong></p>
			</div>
			<p class="joke">No vulnerability here—just a suspiciously missing URL.</p>
			<div class="actions">
				<a href="/" class="primary-action">
					<Icon name="material-symbols:home" />
					Return to safety
				</a>
				<a href="/archive/" class="secondary-action">
					<Icon name="material-symbols:archive" />
					Search the archive
				</a>
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
	.error-shell {
		position: relative;
		min-height: 35rem;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--primary) 45%, transparent);
		background:
			linear-gradient(rgba(66, 245, 141, 0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(66, 245, 141, 0.025) 1px, transparent 1px),
			#050b08;
		background-size: 28px 28px;
		box-shadow: 0 0 50px rgba(66, 245, 141, 0.09);
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: .5rem;
		padding: .8rem 1rem;
		border-bottom: 1px solid rgba(66, 245, 141, .16);
		background: rgba(0, 0, 0, .42);
	}

	.terminal-bar span { width: .7rem; height: .7rem; border-radius: 50%; background: #42f58d; }
	.terminal-bar span:nth-child(2) { opacity: .55; }
	.terminal-bar span:nth-child(3) { opacity: .25; }
	.terminal-bar p { margin-left: .45rem; color: rgba(255,255,255,.55); font: 600 .8rem ui-monospace, monospace; }

	.error-content { position: relative; z-index: 2; padding: 3rem 1.5rem 3.5rem; text-align: center; }
	.glitch-code {
		position: relative;
		display: inline-block;
		font: 900 clamp(6rem, 18vw, 11rem)/.9 ui-monospace, monospace;
		letter-spacing: -.08em;
		color: #42f58d;
		text-shadow: 0 0 12px rgba(66,245,141,.7), 0 0 48px rgba(66,245,141,.28);
		animation: signal 3s steps(1) infinite;
	}
	.glitch-code::before { content: attr(data-text); position: absolute; inset: 0; color: #18cfa2; opacity: .35; transform: translate(4px, 2px); clip-path: inset(38% 0 44%); }

	.status { margin: 1.4rem 0 1rem; color: #42f58d; font: 700 .78rem ui-monospace, monospace; letter-spacing: .18em; }
	.status span { display: inline-block; width: .55rem; height: .55rem; margin-right: .5rem; border-radius: 50%; background: #42f58d; box-shadow: 0 0 12px #42f58d; }
	h1 { max-width: 42rem; margin: 0 auto 1.6rem; color: white; font-size: clamp(1.65rem, 4vw, 2.7rem); font-weight: 800; }

	.terminal-output { max-width: 38rem; margin: 0 auto; padding: 1.15rem 1.3rem; border-left: 2px solid #42f58d; border-radius: .7rem; background: rgba(0,0,0,.48); text-align: left; color: rgba(255,255,255,.62); font: .82rem/1.75 ui-monospace, monospace; }
	.terminal-output b, .terminal-output em { color: #42f58d; font-style: normal; }
	.terminal-output strong { color: #ff7285; font-weight: 700; }
	.joke { margin: 1.4rem auto 1.8rem; color: rgba(255,255,255,.67); }

	.actions { display: flex; flex-wrap: wrap; justify-content: center; gap: .8rem; }
	.actions a { display: inline-flex; align-items: center; gap: .55rem; min-height: 2.8rem; padding: .7rem 1.1rem; border-radius: .7rem; font-weight: 700; transition: transform .18s ease, box-shadow .18s ease; }
	.actions a:hover { transform: translateY(-2px); }
	.primary-action { color: #031008; background: #42f58d; box-shadow: 0 0 24px rgba(66,245,141,.22); }
	.secondary-action { color: #b5f9cf; border: 1px solid rgba(66,245,141,.28); background: rgba(66,245,141,.07); }
	.scanline { position: absolute; inset: -100% 0 auto; height: 100%; z-index: 1; pointer-events: none; background: linear-gradient(transparent, rgba(66,245,141,.06), transparent); animation: scan 7s linear infinite; }

	@keyframes scan { to { transform: translateY(300%); } }
	@keyframes signal { 0%, 95%, 100% { transform: none; } 96% { transform: translateX(-3px); } 97% { transform: translateX(4px); } }
	@media (prefers-reduced-motion: reduce) { .scanline, .glitch-code { animation: none; } }
	@media (max-width: 640px) { .error-shell { min-height: 32rem; } .error-content { padding-inline: 1rem; } .actions { flex-direction: column; } .actions a { justify-content: center; } }
</style>
